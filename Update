import os
from datetime import datetime
import pandas as pd
from tkinter import Tk, filedialog

REPORT_FILE = "folder_scan_report.xlsx"


def choose_folder():
    root = Tk()
    root.withdraw()

    folder = filedialog.askdirectory(
        title="Select Folder to Scan"
    )

    root.destroy()

    return folder


def scan_folder(folder_path):

    data = []

    for root, dirs, files in os.walk(folder_path):

        # Folders
        for folder in dirs:

            full_path = os.path.join(
                root,
                folder
            )

            try:

                modified = datetime.fromtimestamp(
                    os.path.getmtime(
                        full_path
                    )
                )

                data.append({
                    "Type": "Folder",
                    "Name": folder,
                    "Full Path": full_path,
                    "Modified Date": modified
                })

            except Exception:
                pass

        # Files
        for file in files:

            if file == REPORT_FILE:
                continue

            full_path = os.path.join(
                root,
                file
            )

            try:

                modified = datetime.fromtimestamp(
                    os.path.getmtime(
                        full_path
                    )
                )

                size = os.path.getsize(
                    full_path
                )

                data.append({
                    "Type": "File",
                    "Name": file,
                    "Full Path": full_path,
                    "Size (Bytes)": size,
                    "Modified Date": modified
                })

            except Exception:
                pass

    return data


def save_to_excel(
    data,
    folder_path
):

    report_path = os.path.join(
        folder_path,
        REPORT_FILE
    )

    df = pd.DataFrame(data)

    if df.empty:

        print(
            "No files or folders found."
        )

        return

    df["Modified Date"] = pd.to_datetime(
        df["Modified Date"],
        errors="coerce"
    )

    df = df.sort_values(
        by="Modified Date",
        ascending=True
    )

    df["Modified Date"] = (
        df["Modified Date"]
        .dt.strftime(
            "%Y-%m-%d %H:%M:%S"
        )
    )

    df.to_excel(
        report_path,
        index=False
    )

    print(
        f"Report updated:\n{report_path}"
    )

    print(
        f"Total items scanned: {len(df)}"
    )


def main():

    print(
        "Select folder to scan..."
    )

    folder_path = choose_folder()

    if not folder_path:

        print(
            "No folder selected."
        )

        return

    print(
        "Scanning..."
    )

    data = scan_folder(
        folder_path
    )

    save_to_excel(
        data,
        folder_path
    )

    print(
        "Done."
    )


if __name__ == "__main__":
    main()
