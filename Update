import os
import json
from datetime import datetime
import pandas as pd
from tkinter import Tk, filedialog

STATE_FILE = "scan_state.json"
REPORT_FILE = "folder_scan_report.xlsx"


def get_creation_date(path):
    try:
        return datetime.fromtimestamp(os.path.getctime(path))
    except Exception:
        return None


def load_last_scan(folder_path):
    state_path = os.path.join(folder_path, STATE_FILE)

    if not os.path.exists(state_path):
        return datetime.min

    try:
        with open(state_path, "r") as f:
            state = json.load(f)

        return datetime.fromisoformat(state["last_scan"])

    except Exception:
        return datetime.min


def save_last_scan(folder_path, scan_time):
    state_path = os.path.join(folder_path, STATE_FILE)

    with open(state_path, "w") as f:
        json.dump(
            {"last_scan": scan_time.isoformat()},
            f,
            indent=4
        )


def scan_folder(folder_path, last_scan):
    data = []

    for root, dirs, files in os.walk(folder_path):

        for folder in dirs:
            folder_full_path = os.path.join(root, folder)

            creation_date = get_creation_date(folder_full_path)

            if creation_date and creation_date > last_scan:
                data.append({
                    "Name": folder,
                    "Type": "Folder",
                    "Full Path": folder_full_path,
                    "Creation Date": creation_date
                })

        for file in files:
            if file in [REPORT_FILE, STATE_FILE]:
                continue

            file_full_path = os.path.join(root, file)

            creation_date = get_creation_date(file_full_path)

            if creation_date and creation_date > last_scan:
                data.append({
                    "Name": file,
                    "Type": "File",
                    "Full Path": file_full_path,
                    "Creation Date": creation_date
                })

    return data


def save_to_excel(data, folder_path):
    report_path = os.path.join(folder_path, REPORT_FILE)

    new_df = pd.DataFrame(data)

    if new_df.empty:
        print("No new files or folders found.")
        return

    if os.path.exists(report_path):
        existing_df = pd.read_excel(report_path)

        combined_df = pd.concat(
            [existing_df, new_df],
            ignore_index=True
        )
    else:
        combined_df = new_df

    combined_df["Creation Date"] = pd.to_datetime(
        combined_df["Creation Date"],
        errors="coerce"
    )

    combined_df = combined_df.sort_values(
        by="Creation Date"
    )

    combined_df["Creation Date"] = combined_df[
        "Creation Date"
    ].dt.strftime("%Y-%m-%d %H:%M:%S")

    combined_df.to_excel(
        report_path,
        index=False
    )

    print(f"Added {len(new_df)} new items.")
    print(f"Report updated: {report_path}")


def choose_folder():
    root = Tk()
    root.withdraw()

    folder = filedialog.askdirectory(
        title="Select Folder to Scan"
    )

    root.destroy()

    return folder


def main():
    print("Select a folder to scan...")

    folder_path = choose_folder()

    if not folder_path:
        print("No folder selected.")
        return

    last_scan = load_last_scan(folder_path)

    print(f"Last scan: {last_scan}")

    current_scan_time = datetime.now()

    print("Scanning for newly added files/folders...")

    data = scan_folder(
        folder_path,
        last_scan
    )

    save_to_excel(
        data,
        folder_path
    )

    save_last_scan(
        folder_path,
        current_scan_time
    )

    print("Done.")


if __name__ == "__main__":
    main()
